# =============================================================
#  QuensultingAI Dental Receptionist — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================

# ── n8n Configuration ────────────────────────────────────────
# Full public URL of your n8n webhook endpoint
N8N_WEBHOOK_URL=https://<your-n8n-instance>.app.n8n.cloud/webhook/clinic-booking

# ── Google Sheets ─────────────────────────────────────────────
# The ID from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEETS_ID=your_google_sheets_document_id_here

# ── Google Calendar ───────────────────────────────────────────
# The calendar ID (found in Google Calendar settings → Integrate calendar)
# Format: xxxxxxxxxxxx@group.calendar.google.com  (or your Gmail for primary)
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── n8n OAuth2 Credential IDs ─────────────────────────────────
# These are the internal IDs assigned by n8n when you create credentials.
# Found in: n8n → Settings → Credentials → (select credential) → URL bar ID
GMAIL_OAUTH2_CREDENTIAL_ID=your_n8n_gmail_credential_id
GOOGLE_SHEETS_OAUTH2_CREDENTIAL_ID=your_n8n_sheets_credential_id
GOOGLE_CALENDAR_OAUTH2_CREDENTIAL_ID=your_n8n_calendar_credential_id

# ── Retell AI ─────────────────────────────────────────────────
# Your Retell AI API key (found in Retell dashboard → API Keys)
RETELL_API_KEY=your_retell_api_key_here

# ── Clinic Contact ────────────────────────────────────────────
# Direct phone number of the human receptionist (used as fallback in the AI agent)
RECEPTIONIST_PHONE=+91 XXXXX XXXXX
